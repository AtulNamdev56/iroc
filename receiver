void handleRoot() {
  server.send(200, "text/html", INDEX_HTML);
}

void handleData() {
  String json = "{";
  json += "\"x\":"          + String(data.x, 1) + ",";
  json += "\"y\":"          + String(data.y, 1) + ",";
  json += "\"vx\":"         + String(data.vx, 1) + ",";
  json += "\"vy\":"         + String(data.vy, 1) + ",";
  json += "\"alt\":"        + String(data.alt, 1) + ",";
  json += "\"percentage\":" + String(data.percentage, 0);
  json += "}";
  server.send(200, "application/json", json);
}

void handleRelay() {
  relayState = !relayState;
  digitalWrite(RELAY_PIN, relayState ? HIGH : LOW);
  String json = "{\"relay\":";
  json += relayState ? "true" : "false";
  json += "}";
  server.send(200, "application/json", json);
  Serial.print("Charging GPIO2: "); Serial.println(relayState ? "ON" : "OFF");
}

void setup() {
  Serial.begin(115200);
  delay(2000);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, LOW);

  // WiFi FIRST - always accessible
  WiFi.softAP(ssid, password);
  IPAddress ip = WiFi.softAPIP();
  Serial.print("Hotspot: "); Serial.println(ssid);
  Serial.print("Dashboard: http://"); Serial.println(ip);
  server.on("/",      handleRoot);
  server.on("/data",  handleData);
  server.on("/relay", handleRelay);
  server.begin();
  Serial.println("Web server started");

  // NRF AFTER WiFi
  Serial.println("NRF Receiver Starting...");
  SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, CSN_PIN);
  if (!radio.begin()) {
    Serial.println("NRF NOT DETECTED - check wiring & 3.3V power");
    nrfOK = false;
    return;
  }
  nrfOK = true;
  Serial.println("NRF detected");
  radio.setChannel(115);
  radio.setPALevel(RF24_PA_LOW);
  radio.setDataRate(RF24_250KBPS);
  radio.openReadingPipe(0, address);
  radio.startListening();
}

void loop() {
  server.handleClient();
  if (nrfOK && radio.available()) {
    radio.read(&data, sizeof(data));
    Serial.print("X: "); Serial.print(data.x, 1);
    Serial.print(" cm | Y: "); Serial.print(data.y, 1);
    Serial.print(" | VX: "); Serial.print(data.vx, 1);
    Serial.print(" cm/s | VY: "); Serial.print(data.vy, 1);
    Serial.print(" | ALT: "); Serial.print(data.alt, 1); Serial.print(" cm");
    Serial.print(" | BAT: "); Serial.print(data.percentage, 0); Serial.println(" %");
  }
}
